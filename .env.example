# LLM Provider Configuration
# Options: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Default model to use
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=gemma3:4b

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Enterprise Infrastructure ---
# Redis (Task Queue Broker & State Cache)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (Multi-tenant Database)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/iksha

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=iksha

# Qdrant (Vector Database)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=candidates

# Keycloak (Identity & Access Management)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=iksha
AUTH_ENABLED=true
